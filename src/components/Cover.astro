---
const { entry, width = 1200, eager = false, class: cls = '' } = Astro.props;
const src = entry.data.cover || '/images/default-cover.jpg';
const loading = eager ? 'eager' : 'lazy';
const fetchpriority = eager ? 'high' : 'auto';
---
<img class={cls} src={src} alt={entry.data.title} loading={loading} fetchpriority={fetchpriority} width={width} height={Math.round(width * 0.5625)} />
