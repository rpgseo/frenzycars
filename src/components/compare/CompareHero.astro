---
import type { CarRow } from '../../lib/d1-client.js';

interface Props {
  rowA: CarRow;
  rowB: CarRow;
  scoreA: number;
  scoreB: number;
}
const { rowA, rowB, scoreA, scoreB } = Astro.props;
const winner = scoreA > scoreB ? rowA : scoreB > scoreA ? rowB : null;

function pressImage(row: CarRow) {
  return `/press/${row.make.toLowerCase()}/${row.slug}/hero.jpg`;
}
function fallback(row: CarRow) {
  return `https://images.unsplash.com/photo-1494976388531-d1058494cdd8?auto=format&fit=crop&w=800&q=80`;
}
---
<header class="compare-hero">
  <nav aria-label="Breadcrumb" class="breadcrumb">
    <a href="/">Home</a> › <a href="/compare/">Compare</a> ›
    <span>{rowA.make} {rowA.model} vs {rowB.make} {rowB.model}</span>
  </nav>

  <h1 class="compare-title">
    {rowA.make} {rowA.model} {rowA.trim} {rowA.year}
    <span class="vs">vs</span>
    {rowB.make} {rowB.model} {rowB.trim} {rowB.year}
  </h1>

  <div class="hero-grid">
    {[rowA, rowB].map((row, i) => {
      const score = i === 0 ? scoreA : scoreB;
      const isWinner = winner?.slug === row.slug;
      return (
        <div class:list={['car-card', { winner: isWinner }]}>
          {isWinner && <div class="winner-badge">Comparison Winner</div>}
          <img
            src={pressImage(row)}
            alt={`${row.make} ${row.model} ${row.trim}`}
            width="480" height="300"
            loading="eager"
            fetchpriority={i === 0 ? 'high' : 'auto'}
            onerror={`this.src='${fallback(row)}'`}
            transition:name={`car-hero-${row.slug}`}
          />
          <div class="car-meta">
            <div class="score-ring" aria-label={`Score: ${score}/100`}>
              <svg viewBox="0 0 36 36" width="64" height="64">
                <circle cx="18" cy="18" r="15.9" fill="none" stroke="#222" stroke-width="3"/>
                <circle cx="18" cy="18" r="15.9" fill="none" stroke="#F7D720"
                  stroke-width="3"
                  stroke-dasharray={`${score} ${100 - score}`}
                  stroke-dashoffset="25"
                  transform="rotate(-90 18 18)"
                />
                <text x="18" y="22" text-anchor="middle" font-size="9" fill="#fff" font-weight="bold">{score}</text>
              </svg>
            </div>
            <h2>{row.make} {row.model}</h2>
            <p class="trim-year">{row.trim} · {row.year}</p>
          </div>
        </div>
      );
    })}
  </div>
</header>

<style>
.compare-hero { padding: 2rem 0 1rem; }
.breadcrumb { font-size: 0.85rem; color: #888; margin-bottom: 1rem; }
.breadcrumb a { color: #888; text-decoration: none; }
.compare-title { font-size: clamp(1.4rem, 4vw, 2.2rem); font-weight: 900; margin-bottom: 2rem; }
.compare-title .vs { display: inline-block; background: #F7D720; color: #000; padding: 0.1em 0.4em; border-radius: 4px; font-size: 0.7em; margin: 0 0.4em; vertical-align: middle; }
.hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
@media (max-width: 640px) { .hero-grid { grid-template-columns: 1fr; } }
.car-card { position: relative; background: #111; border-radius: 12px; overflow: hidden; }
.car-card.winner { outline: 2px solid #F7D720; }
.winner-badge { background: #F7D720; color: #000; font-weight: 800; font-size: 0.75rem; text-align: center; padding: 0.3rem; }
.car-card img { width: 100%; height: 220px; object-fit: cover; display: block; }
.car-meta { padding: 1rem; display: flex; align-items: center; gap: 1rem; }
.score-ring svg { flex-shrink: 0; }
.car-meta h2 { font-size: 1.1rem; font-weight: 800; margin: 0 0 0.25rem; }
.trim-year { font-size: 0.85rem; color: #888; margin: 0; }
</style>
