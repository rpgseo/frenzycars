---
interface Props {
  currentSlug: string;
  slugA: string;
  slugB: string;
}
const { currentSlug, slugA, slugB } = Astro.props;

const CF_ACCOUNT_ID = import.meta.env.CF_ACCOUNT_ID ?? process.env.CF_ACCOUNT_ID;
const CF_API_TOKEN = import.meta.env.CF_API_TOKEN ?? process.env.CF_API_TOKEN;
const D1_DATABASE_ID = 'b9d5f455-8e9e-439c-9283-ef1b19addf4b';

let related: Array<{ url_slug: string; slug_a: string; slug_b: string }> = [];
try {
  const res = await fetch(
    `https://api.cloudflare.com/client/v4/accounts/${CF_ACCOUNT_ID}/d1/database/${D1_DATABASE_ID}/query`,
    {
      method: 'POST',
      headers: { Authorization: `Bearer ${CF_API_TOKEN}`, 'Content-Type': 'application/json' },
      body: JSON.stringify({
        sql: "SELECT url_slug, slug_a, slug_b FROM comparisons WHERE published=1 AND url_slug != ? AND (slug_a IN (?,?) OR slug_b IN (?,?)) LIMIT 6",
        params: [currentSlug, slugA, slugB, slugA, slugB],
      }),
    }
  );
  const data = await res.json() as any;
  if (data.success) related = data.result?.[0]?.results ?? [];
} catch {
  // D1 unavailable — silently skip related comparisons
}
---
{related.length > 0 && (
  <section class="related">
    <h2>Related Comparisons</h2>
    <ul>
      {related.map(r => (
        <li><a href={`/compare/${r.url_slug}/`}>{r.slug_a} vs {r.slug_b}</a></li>
      ))}
    </ul>
  </section>
)}

<style>
.related { margin: 3rem 0; }
.related h2 { font-size: 1.2rem; font-weight: 800; margin-bottom: 1rem; }
.related ul { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: 0.5rem; }
.related a { background: #111; padding: 0.4rem 0.8rem; border-radius: 6px; font-size: 0.85rem; color: #ccc; text-decoration: none; }
.related a:hover { color: #F7D720; }
</style>
