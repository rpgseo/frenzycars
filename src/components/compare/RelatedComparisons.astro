---
import { execSync } from 'child_process';

interface Props {
  currentSlug: string;
  slugA: string;
  slugB: string;
}
const { currentSlug, slugA, slugB } = Astro.props;

// At build time, query D1 for related comparisons via wrangler CLI
let related: Array<{ url_slug: string; slug_a: string; slug_b: string }> = [];
try {
  if (!process.env.WRANGLER_D1_SKIP) {
    const out = execSync(
      `npx wrangler d1 execute frenzycars-cars --local --json --command="SELECT url_slug, slug_a, slug_b FROM comparisons WHERE published=1 AND url_slug != '${currentSlug}' AND (slug_a IN ('${slugA}','${slugB}') OR slug_b IN ('${slugA}','${slugB}')) LIMIT 6"`,
      { encoding: 'utf8', cwd: process.cwd() }
    );
    const parsed = JSON.parse(out);
    related = parsed[0]?.results ?? [];
  }
} catch {
  // D1 unavailable
}
---
{related.length > 0 && (
  <section class="related">
    <h2>Related Comparisons</h2>
    <ul>
      {related.map(r => (
        <li><a href={`/comparar/${r.url_slug}/`}>{r.slug_a} vs {r.slug_b}</a></li>
      ))}
    </ul>
  </section>
)}

<style>
.related { margin: 3rem 0; }
.related h2 { font-size: 1.2rem; font-weight: 800; margin-bottom: 1rem; }
.related ul { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: 0.5rem; }
.related a { background: #111; padding: 0.4rem 0.8rem; border-radius: 6px; font-size: 0.85rem; color: #ccc; text-decoration: none; }
.related a:hover { color: #F7D720; }
</style>
