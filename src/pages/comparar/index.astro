---
import Base from '../../layouts/Base.astro';

// At build time, read published comparisons from D1
// During local dev without D1, show empty state
let comparisons: Array<{ url_slug: string; slug_a: string; slug_b: string }> = [];
try {
  const db = (Astro.locals as any).runtime?.env?.DB;
  if (db) {
    const result = await db.prepare(
      'SELECT url_slug, slug_a, slug_b FROM comparisons WHERE published=1 ORDER BY monthly_searches DESC LIMIT 100'
    ).all();
    comparisons = result.results ?? [];
  }
} catch {}
---
<Base title="Car Comparisons — FrenzyCars" description="Side-by-side car comparisons with full specs, performance data, and expert analysis.">
  <section class="compare-hub">
    <h1>Car Comparisons</h1>
    <p class="lead">In-depth side-by-side comparisons with specs, charts, and expert verdicts.</p>
    {comparisons.length === 0 ? (
      <p>Comparisons coming soon.</p>
    ) : (
      <ul class="comparison-list">
        {comparisons.map(c => (
          <li>
            <a href={`/comparar/${c.url_slug}/`}>
              {c.slug_a} vs {c.slug_b}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</Base>

<style>
.compare-hub { max-width: 900px; margin: 2rem auto; padding: 0 1rem; }
.comparison-list { list-style: none; padding: 0; display: grid; gap: 0.5rem; }
.comparison-list a { color: var(--accent, #F7D720); text-decoration: none; font-weight: 600; }
.comparison-list a:hover { text-decoration: underline; }
</style>
