---
export const prerender = false;

import ContentLayout from '../../layouts/ContentLayout.astro';
import CandidateActions from '../../components/content/CandidateActions.tsx';
import { getD1 } from '../../lib/d1-client.js';
import { getCandidate } from '../../lib/reviews-d1.js';
import type { CandidateStatus } from '../../lib/reviews-d1.js';

const STATUS_LABELS: Record<CandidateStatus, string> = {
  suggested: 'Suggested',
  approved: 'Approved',
  rejected: 'Rejected',
  published: 'Published',
};

const STATUS_COLORS: Record<CandidateStatus, string> = {
  suggested: '#888',
  approved: '#22c55e',
  rejected: '#ef4444',
  published: '#3b82f6',
};

const rawId = Astro.params.id;
const id = rawId ? parseInt(rawId, 10) : NaN;

if (!Number.isFinite(id)) {
  return Astro.redirect('/content/');
}

const db = getD1(Astro.locals);
if (!db) {
  return new Response('D1 not available', { status: 503 });
}

const candidate = await getCandidate(db, id);
if (!candidate) {
  return new Response('Candidate not found', { status: 404 });
}

const color = STATUS_COLORS[candidate.status];
---
<ContentLayout title={`${candidate.make} ${candidate.model}`}>
  <style>
    .back { color: #F7D720; text-decoration: none; font-size: 0.85rem; display: inline-block; margin-bottom: 1.5rem; }
    .back:hover { text-decoration: underline; }
    .car-heading { display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem; flex-wrap: wrap; }
    .car-heading h1 { margin: 0; }
    .badge { display: inline-block; padding: 0.25rem 0.8rem; border-radius: 999px;
      font-size: 0.8rem; font-weight: 700; }
    .sections { display: grid; gap: 1.5rem; }
    .section { background: #111; border: 1px solid #1e1e1e; border-radius: 10px; padding: 1.5rem; }
    .section-title { font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.08em; color: #555; margin-bottom: 1rem; }
    .grid-2 { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; }
    .stat { }
    .stat-label { font-size: 0.75rem; color: #555; margin-bottom: 0.2rem; }
    .stat-value { font-weight: 600; color: #e5e5e5; }
    .stat-value.empty { color: #333; font-style: italic; font-weight: 400; }
    .image-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1rem; }
    .image-placeholder { background: #1a1a1a; border: 1px dashed #2a2a2a; border-radius: 8px;
      aspect-ratio: 16/9; display: flex; flex-direction: column; align-items: center;
      justify-content: center; color: #333; font-size: 0.75rem; text-align: center; gap: 0.4rem; }
    .image-preview { border-radius: 8px; width: 100%; aspect-ratio: 16/9; object-fit: cover; }
    .raw-data { background: #0a0a0a; border-radius: 6px; padding: 1rem;
      font-size: 0.8rem; color: #666; font-family: monospace; overflow-x: auto; white-space: pre-wrap; }
    .prompt-text { font-size: 0.85rem; color: #888; font-style: italic; line-height: 1.5; }
  </style>

  <a href="/content/" class="back">← Back to pipeline</a>

  <div class="car-heading">
    <h1>{candidate.make} {candidate.model}{candidate.year ? ` ${candidate.year}` : ''}</h1>
    <span class="badge" style={`background:${color}22; color:${color}; border:1px solid ${color}44`}>
      {STATUS_LABELS[candidate.status]}
    </span>
  </div>

  <div class="sections">

    <!-- SEO -->
    <div class="section">
      <div class="section-title">SEO Data (Step 1)</div>
      <div class="grid-2">
        <div class="stat">
          <div class="stat-label">Keyword</div>
          <div class:list={['stat-value', { empty: !candidate.keyword }]}>{candidate.keyword ?? 'Not set yet'}</div>
        </div>
        <div class="stat">
          <div class="stat-label">Monthly Volume</div>
          <div class:list={['stat-value', { empty: !candidate.search_volume }]}>
            {candidate.search_volume ? candidate.search_volume.toLocaleString() : 'Not set yet'}
          </div>
        </div>
        <div class="stat">
          <div class="stat-label">Keyword Difficulty</div>
          <div class:list={['stat-value', { empty: candidate.keyword_difficulty == null }]}>
            {candidate.keyword_difficulty ?? 'Not set yet'}
          </div>
        </div>
        <div class="stat">
          <div class="stat-label">Trend Score</div>
          <div class:list={['stat-value', { empty: candidate.trend_score == null }]}>
            {candidate.trend_score ?? 'Not set yet'}
          </div>
        </div>
      </div>
    </div>

    <!-- Images -->
    <div class="section">
      <div class="section-title">Images (Steps 2–3)</div>
      <div class="image-grid">
        {candidate.reference_image_url ? (
          <img src={candidate.reference_image_url} alt="Reference" class="image-preview" />
        ) : (
          <div class="image-placeholder">
            <span>📷</span>
            <span>Reference image<br/>not fetched yet</span>
          </div>
        )}
        {candidate.editorial_hero_url ? (
          <img src={candidate.editorial_hero_url} alt="Editorial hero" class="image-preview" />
        ) : (
          <div class="image-placeholder">
            <span>🎨</span>
            <span>Editorial hero<br/>not generated yet</span>
          </div>
        )}
        {candidate.editorial_mid1_url ? (
          <img src={candidate.editorial_mid1_url} alt="Editorial mid 1" class="image-preview" />
        ) : (
          <div class="image-placeholder">
            <span>🎨</span>
            <span>Mid image 1<br/>not generated yet</span>
          </div>
        )}
        {candidate.editorial_mid2_url ? (
          <img src={candidate.editorial_mid2_url} alt="Editorial mid 2" class="image-preview" />
        ) : (
          <div class="image-placeholder">
            <span>🎨</span>
            <span>Mid image 2<br/>not generated yet</span>
          </div>
        )}
      </div>
      {candidate.hero_prompt && (
        <div style="margin-top:1rem">
          <div class="stat-label" style="margin-bottom:0.4rem">Hero prompt</div>
          <p class="prompt-text">{candidate.hero_prompt}</p>
        </div>
      )}
    </div>

    <!-- Video -->
    <div class="section">
      <div class="section-title">Video (Step 4)</div>
      {candidate.video_url ? (
        <video src={candidate.video_url} controls style="width:100%; border-radius:8px; max-width:640px" />
      ) : (
        <div class="image-placeholder" style="max-width:320px; aspect-ratio:16/9">
          <span>🎬</span>
          <span>Video not generated yet</span>
        </div>
      )}
    </div>

    <!-- Raw data -->
    <div class="section">
      <div class="section-title">Scraped Data (Step 5)</div>
      {candidate.raw_data ? (
        <pre class="raw-data">{JSON.stringify(JSON.parse(candidate.raw_data), null, 2)}</pre>
      ) : (
        <p class="stat-value empty">Data not collected yet</p>
      )}
    </div>

    <!-- Actions -->
    <div class="section">
      <div class="section-title">Actions</div>
      <CandidateActions id={candidate.id} initialStatus={candidate.status} client:visible />
    </div>

  </div>
</ContentLayout>
