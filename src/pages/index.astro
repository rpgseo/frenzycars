---
import Base from '../layouts/Base.astro';
import LeadCard from '../components/LeadCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Cover from '../components/Cover.astro';
import Sidebar from '../components/Sidebar.astro';
import { getCollection } from 'astro:content';
import { humanize } from '../lib/section';

// ── Cargar todas las colecciones editoriales ──────────────────────────────────
const sections = ['reviews','news','culture','electric','guides','insurance','gear','blog'];
let all: any[] = (await Promise.all(sections.map(s => getCollection(s as any)))).flat().filter((e: any) => !e.data.draft);
all.sort((a: any, b: any) => (+new Date(b.data.date || 0)) - (+new Date(a.data.date || 0)));

// ── De-duplicación: Set global de slugs ya usados ────────────────────────────
const seenSlugs = new Set<string>();

function pick(items: any[], n: number): any[] {
  const result: any[] = [];
  for (const item of items) {
    if (seenSlugs.has(item.id)) continue;
    seenSlugs.add(item.id);
    result.push(item);
    if (result.length === n) break;
  }
  return result;
}

const url = (e: AnyEntry) => `/${e.collection}/${e.id.replace(/\.mdx?$/, '')}/`;

// ── Bloque 0 — Ticker: 3 más recientes (no consume seenSlugs) ────────────────
const tickerItems = all.slice(0, 3);

// ── Bloque 1 — Hero: 1 featured + 2 secundarias ──────────────────────────────
const featuredPool = all.filter((e: any) => e.data.featured);
const [heroMain] = pick(featuredPool.length ? featuredPool : all, 1);
// Las secundarias son news o electric preferentemente, de lo que quede
const secondaryPool = all.filter((e: any) => e.collection === 'news' || e.collection === 'electric');
const heroSecondary = pick(secondaryPool.length >= 2 ? secondaryPool : all, 2);

// ── Bloque 2 — Últimas noticias: 4 de news ───────────────────────────────────
const newsSorted = all.filter((e: any) => e.collection === 'news');
const latestNews = pick(newsSorted, 4);

// ── Bloque 3 — Reviews por rating ────────────────────────────────────────────
const reviewsByRating = all
  .filter((e: any) => e.collection === 'reviews')
  .sort((a: any, b: any) => (b.data.rating ?? 0) - (a.data.rating ?? 0));
const topReviews = pick(reviewsByRating, 6);

// Bloque 4 — Herramientas: sin posts, no pasa por pick()

// ── Bloque 5 — Eléctrico + Guías ─────────────────────────────────────────────
const electricPosts = pick(all.filter((e: any) => e.collection === 'electric'), 2);
const guidePosts    = pick(all.filter((e: any) => e.collection === 'guides'), 2);

// ── Bloque 6 — Blog ──────────────────────────────────────────────────────────
const blogPosts = pick(all.filter((e: any) => e.collection === 'blog'), 3);

// ── Bloque 7 — Cultura + Seguros ─────────────────────────────────────────────
const culturePosts   = pick(all.filter((e: any) => e.collection === 'culture'), 2);
const insurancePosts = pick(all.filter((e: any) => e.collection === 'insurance'), 2);
---

<Base
  title={undefined}
  description="Expert car reviews, breaking auto news, and in-depth features on performance cars, EVs, and car culture. FrenzyCars — driven by obsession."
>
  {/* ── Bloque 0 — Ticker de frescura ────────────────────────────────────── */}
  {tickerItems.length > 0 && (
    <div class="news-ticker" aria-label="Últimas publicaciones">
      <div class="news-ticker-track">
        {[...tickerItems, ...tickerItems].map((e: any, i: number) => (
          <span class="news-ticker-item">
            <span class="news-ticker-tag">{humanize(e.collection)}</span>
            <a class="news-ticker-link" href={url(e)}>{e.data.title}</a>
            <span class="news-ticker-sep" aria-hidden="true">◆</span>
          </span>
        ))}
      </div>
    </div>
  )}

  <div class="container">
    {/* ── Bloque 1 — Hero ──────────────────────────────────────────────────── */}
    {heroMain && (
      <section class="zone">
        <div class="lead-grid">
          <LeadCard entry={heroMain as any} />
          <div class="lead-secondary">
            {heroSecondary.map((e: any) => (
              <a class="lead-sec" href={url(e)}>
                <Cover entry={e} width={600} class="lead-sec-img" />
                <div class="lead-sec-overlay"></div>
                <div class="lead-sec-body">
                  <span class="eyebrow">{humanize(e.collection)}</span>
                  <h2 class="lead-sec-title">{e.data.title}</h2>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* ── Bloque 2 — Últimas noticias ──────────────────────────────────────── */}
    {latestNews.length > 0 && (
      <section class="zone">
        <div class="zone-head">
          <h2 class="zone-title"><span class="title-marker">//</span> Latest News</h2>
          <a class="zone-link" href="/news/">All news &rarr;</a>
        </div>
        <div class="grid grid-4">
          {latestNews.map((e: any) => <ArticleCard entry={e} />)}
        </div>
      </section>
    )}

    {/* ── Bloque 3 — Reviews destacadas por rating ─────────────────────────── */}
    {topReviews.length > 0 && (
      <section class="zone">
        <div class="zone-head">
          <h2 class="zone-title"><span class="title-marker">//</span> Reviews</h2>
          <a class="zone-link" href="/reviews/">All reviews &rarr;</a>
        </div>
        <div class="grid grid-3">
          {topReviews.map((e: any) => <ArticleCard entry={e} />)}
        </div>
      </section>
    )}

    {/* ── Bloque 4 — Herramientas interactivas ─────────────────────────────── */}
    <section class="zone zone-tools">
      <h2 class="zone-title"><span class="title-marker">//</span> FrenzyCars Tools</h2>
      <div class="tools-grid">
        <a class="tool-card" href="/comparar/">
          <span class="tool-icon" aria-hidden="true">⚖️</span>
          <div class="tool-body">
            <h3 class="tool-title">Car Comparator</h3>
            <p class="tool-desc">Compare specs, performance and price side by side across hundreds of models.</p>
            <span class="btn btn-accent">Compare now &rarr;</span>
          </div>
        </a>
        <a class="tool-card" href="/maintenance/">
          <span class="tool-icon" aria-hidden="true">🔧</span>
          <div class="tool-body">
            <h3 class="tool-title">Repair &amp; Maintenance Guides</h3>
            <p class="tool-desc">Step-by-step guides for 150+ common issues. Diagnose your car before the mechanic does.</p>
            <span class="btn btn-accent">Browse guides &rarr;</span>
          </div>
        </a>
      </div>
    </section>

    {/* ── Bloques 5-7 — con sidebar desde Electric/Guides ─────────────────── */}
    <div class="has-rail">
      <div class="main-col">

        {/* ── Bloque 5 — Eléctrico + Guías ──────────────────────────────────── */}
        {(electricPosts.length > 0 || guidePosts.length > 0) && (
          <section class="zone zone-split">
            {electricPosts.length > 0 && (
              <div class="split-col">
                <div class="zone-head">
                  <h2 class="zone-title"><span class="title-marker">//</span> Electric</h2>
                  <a class="zone-link" href="/electric/">All electric &rarr;</a>
                </div>
                <div class={`grid grid-${electricPosts.length > 1 ? '2' : '1'}`}>
                  {electricPosts.map((e: any) => <ArticleCard entry={e} />)}
                </div>
              </div>
            )}
            {guidePosts.length > 0 && (
              <div class="split-col">
                <div class="zone-head">
                  <h2 class="zone-title"><span class="title-marker">//</span> Guides</h2>
                  <a class="zone-link" href="/guides/">All guides &rarr;</a>
                </div>
                <div class={`grid grid-${guidePosts.length > 1 ? '2' : '1'}`}>
                  {guidePosts.map((e: any) => <ArticleCard entry={e} />)}
                </div>
              </div>
            )}
          </section>
        )}

        {/* ── Bloque 6 — Blog ────────────────────────────────────────────────── */}
        {blogPosts.length > 0 && (
          <section class="zone">
            <div class="zone-head">
              <h2 class="zone-title"><span class="title-marker">//</span> Blog</h2>
              <a class="zone-link" href="/blog/">All posts &rarr;</a>
            </div>
            <div class={`grid grid-${Math.min(blogPosts.length, 3) === 1 ? '1' : Math.min(blogPosts.length, 3) === 2 ? '2' : '3'}`}>
              {blogPosts.map((e: any) => <ArticleCard entry={e} />)}
            </div>
          </section>
        )}

        {/* ── Bloque 7 — Cultura + Seguros ───────────────────────────────────── */}
        {(culturePosts.length > 0 || insurancePosts.length > 0) && (
          <section class="zone">
            {culturePosts.length > 0 && (
              <div class="sub-zone">
                <div class="zone-head">
                  <h2 class="zone-title"><span class="title-marker">//</span> Culture</h2>
                  <a class="zone-link" href="/culture/">All culture &rarr;</a>
                </div>
                <div class="grid grid-2">
                  {culturePosts.map((e: any) => <ArticleCard entry={e} />)}
                </div>
              </div>
            )}
            {insurancePosts.length > 0 && (
              <div class="sub-zone">
                <div class="zone-head">
                  <h2 class="zone-title"><span class="title-marker">//</span> Insurance &amp; Costs</h2>
                  <a class="zone-link" href="/insurance/">All insurance &rarr;</a>
                </div>
                <div class="grid grid-2">
                  {insurancePosts.map((e: any) => <ArticleCard entry={e} />)}
                </div>
              </div>
            )}
          </section>
        )}

      </div>
      <aside class="rail" aria-label="Sidebar">
        <div class="rail-sticky"><Sidebar /></div>
      </aside>
    </div>
  </div>

  {/* ── Bloque 7 — Newsletter CTA ─────────────────────────────────────────── */}
  <section class="cta">
    <div class="container cta-inner">
      <h2>Fuel your obsession.</h2>
      <p>Join 50,000 readers getting FrenzyCars in their inbox every week.</p>
      <form
        method="post"
        action="https://sendfox.com/form/3e768w/10jj8x"
        class="newsletter-form cta-form sendfox-form"
        id="10jj8x-cta"
        data-async="true"
        data-recaptcha="true"
      >
        <label class="sr-only" for="cta-email">Email address</label>
        <input id="cta-email" type="email" placeholder="you@email.com" name="email" required />
        <div style="position:absolute;left:-5000px;" aria-hidden="true">
          <input type="text" name="a_password" tabindex="-1" value="" autocomplete="off" />
        </div>
        <button type="submit">Subscribe</button>
      </form>
      <script src="https://cdn.sendfox.com/js/form.js" charset="utf-8" is:inline></script>
    </div>
  </section>
</Base>
