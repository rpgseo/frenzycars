---
import Base from '../../layouts/Base.astro';
import CompareSelector from '../../components/compare/CompareSelector.tsx';
import { loadCompareIndex } from '../../lib/compare-index.js';

interface CompRow {
  url_slug: string;
  make_a: string; model_a: string; trim_a: string; year_a: number | null;
  make_b: string; model_b: string; trim_b: string; year_b: number | null;
  monthly_searches: number | null;
}

let comparisons: CompRow[] = [];
if (!process.env.WRANGLER_D1_SKIP) {
  const CF_ACCOUNT_ID = import.meta.env.CF_ACCOUNT_ID;
  const CF_API_TOKEN = import.meta.env.CF_API_TOKEN;
  const D1_DATABASE_ID = 'b9d5f455-8e9e-439c-9283-ef1b19addf4b';
  try {
    const res = await fetch(
      `https://api.cloudflare.com/client/v4/accounts/${CF_ACCOUNT_ID}/d1/database/${D1_DATABASE_ID}/query`,
      {
        method: 'POST',
        headers: { Authorization: `Bearer ${CF_API_TOKEN}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({
          sql: `SELECT c.url_slug, c.monthly_searches, a.make AS make_a, a.model AS model_a, a.trim AS trim_a, a.year AS year_a, b.make AS make_b, b.model AS model_b, b.trim AS trim_b, b.year AS year_b FROM comparisons c JOIN cars a ON a.slug=c.slug_a JOIN cars b ON b.slug=c.slug_b WHERE c.published=1 ORDER BY c.monthly_searches DESC NULLS LAST, c.kd ASC LIMIT 24`,
        }),
      }
    );
    const data = await res.json() as any;
    if (data.success) comparisons = data.result?.[0]?.results ?? [];
  } catch (e) {
    console.warn('[compare] hub: D1 unavailable.', e);
  }
}

const compareIndex = await loadCompareIndex();

function carName(make: string, model: string, trim: string, year: number | null): string {
  const base = `${make} ${model} ${trim}`.trim();
  return year ? `${base} (${year})` : base;
}
---
<Base title="Car Comparisons — FrenzyCars" description="Side-by-side car comparisons with full specs, performance data, and expert analysis.">
  <section class="compare-hub">
    <h1>Car Comparisons</h1>
    <p class="lead">Pick any two cars and get a full side-by-side breakdown — specs, performance, and a clear verdict.</p>
    <CompareSelector client:visible cars={compareIndex.cars} pairs={compareIndex.pairs} metas={compareIndex.metas} />

    {comparisons.length > 0 && (
      <div class="popular-section">
        <h2>Most Searched Comparisons</h2>
        <div class="comparison-grid">
          {comparisons.map(c => (
            <a href={`/compare/${c.url_slug}/`} class="comparison-card">
              <div class="comparison-card__car">
                <span class="comparison-card__make">{c.make_a}</span>
                <span class="comparison-card__model">{c.model_a} {c.trim_a}</span>
                {c.year_a && <span class="comparison-card__year">{c.year_a}</span>}
              </div>
              <div class="comparison-card__vs">VS</div>
              <div class="comparison-card__car">
                <span class="comparison-card__make">{c.make_b}</span>
                <span class="comparison-card__model">{c.model_b} {c.trim_b}</span>
                {c.year_b && <span class="comparison-card__year">{c.year_b}</span>}
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </section>
</Base>

<style>
.compare-hub { max-width: 960px; margin: 2rem auto; padding: 0 1rem 4rem; }
</style>
