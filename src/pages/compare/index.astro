---
import Base from '../../layouts/Base.astro';
import { execSync } from 'child_process';
import CompareSelector from '../../components/compare/CompareSelector.tsx';
import { loadCompareIndex } from '../../lib/compare-index.js';

interface CompRow {
  url_slug: string;
  make_a: string; model_a: string; trim_a: string; year_a: number | null;
  make_b: string; model_b: string; trim_b: string; year_b: number | null;
  monthly_searches: number | null;
}

let comparisons: CompRow[] = [];
try {
  if (!process.env.WRANGLER_D1_SKIP) {
    const out = execSync(
      `npx wrangler d1 execute frenzycars-cars --local --json --command="SELECT c.url_slug, c.monthly_searches, a.make AS make_a, a.model AS model_a, a.trim AS trim_a, a.year AS year_a, b.make AS make_b, b.model AS model_b, b.trim AS trim_b, b.year AS year_b FROM comparisons c JOIN cars a ON a.slug=c.slug_a JOIN cars b ON b.slug=c.slug_b WHERE c.published=1 ORDER BY c.monthly_searches DESC NULLS LAST, c.kd ASC LIMIT 24"`,
      { encoding: 'utf8', cwd: process.cwd() }
    );
    const parsed = JSON.parse(out);
    comparisons = parsed[0]?.results ?? [];
  }
} catch {
  // D1 unavailable in CI
}

const compareIndex = await loadCompareIndex();

function carName(make: string, model: string, trim: string, year: number | null): string {
  const base = `${make} ${model} ${trim}`.trim();
  return year ? `${base} (${year})` : base;
}
---
<Base title="Car Comparisons — FrenzyCars" description="Side-by-side car comparisons with full specs, performance data, and expert analysis." noindex={true}>
  <section class="compare-hub">
    <h1>Car Comparisons</h1>
    <p class="lead">Pick any two cars and get a full side-by-side breakdown — specs, performance, and a clear verdict.</p>
    <CompareSelector client:visible cars={compareIndex.cars} pairs={compareIndex.pairs} metas={compareIndex.metas} />

    {comparisons.length > 0 && (
      <div class="popular-section">
        <h2>Most Searched Comparisons</h2>
        <div class="comparison-grid">
          {comparisons.map(c => (
            <a href={`/compare/${c.url_slug}/`} class="comparison-card">
              <span class="car-a">{carName(c.make_a, c.model_a, c.trim_a, c.year_a)}</span>
              <span class="vs-badge">vs</span>
              <span class="car-b">{carName(c.make_b, c.model_b, c.trim_b, c.year_b)}</span>
              {c.monthly_searches && (
                <span class="searches">{c.monthly_searches.toLocaleString('en-US')} searches/mo</span>
              )}
            </a>
          ))}
        </div>
      </div>
    )}
  </section>
</Base>

<style>
.compare-hub { max-width: 960px; margin: 2rem auto; padding: 0 1rem 4rem; }
</style>
