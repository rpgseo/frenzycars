---
import Base from '../../layouts/Base.astro';
import { execSync } from 'child_process';
import CompareSelector from '../../components/compare/CompareSelector.tsx';
import { loadCompareIndex } from '../../lib/compare-index.js';

interface CompRow {
  url_slug: string;
  make_a: string; model_a: string; trim_a: string; year_a: number | null;
  make_b: string; model_b: string; trim_b: string; year_b: number | null;
}

let comparisons: CompRow[] = [];
try {
  if (!process.env.WRANGLER_D1_SKIP) {
    const out = execSync(
      `npx wrangler d1 execute frenzycars-cars --local --json --command="SELECT c.url_slug, a.make AS make_a, a.model AS model_a, a.trim AS trim_a, a.year AS year_a, b.make AS make_b, b.model AS model_b, b.trim AS trim_b, b.year AS year_b FROM comparisons c JOIN cars a ON a.slug=c.slug_a JOIN cars b ON b.slug=c.slug_b WHERE c.published=1 ORDER BY c.kd ASC LIMIT 100"`,
      { encoding: 'utf8', cwd: process.cwd() }
    );
    const parsed = JSON.parse(out);
    comparisons = parsed[0]?.results ?? [];
  }
} catch {
  // D1 unavailable in CI — render empty hub
}

const compareIndex = await loadCompareIndex();

function rowLabel(r: CompRow, side: 'a' | 'b'): string {
  const year = side === 'a' ? r.year_a : r.year_b;
  const base = `${side === 'a' ? r.make_a : r.make_b} ${side === 'a' ? r.model_a : r.model_b} ${side === 'a' ? r.trim_a : r.trim_b}`.trim();
  return year ? `${base} (${year})` : base;
}
---
<Base title="Car Comparisons — FrenzyCars" description="Side-by-side car comparisons with full specs, performance data, and expert analysis." noindex={true}>
  <section class="compare-hub">
    <h1>Car Comparisons</h1>
    <p class="lead">In-depth side-by-side comparisons with specs, charts, and expert verdicts.</p>
    <CompareSelector client:visible cars={compareIndex.cars} pairs={compareIndex.pairs} metas={compareIndex.metas} />
    {comparisons.length === 0 ? (
      <p>Comparisons coming soon.</p>
    ) : (
      <ul class="comparison-list">
        {comparisons.map(c => (
          <li>
            <a href={`/compare/${c.url_slug}/`}>
              {rowLabel(c, 'a')} vs {rowLabel(c, 'b')}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</Base>

<style>
.compare-hub { max-width: 960px; margin: 2rem auto; padding: 0 1rem; }
.comparison-list { list-style: none; padding: 0; display: grid; gap: 0.5rem; margin-top: 2rem; }
.comparison-list a { color: var(--accent, #F7D720); text-decoration: none; font-weight: 600; }
.comparison-list a:hover { text-decoration: underline; }
</style>
