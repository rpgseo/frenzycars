---
import type { GetStaticPaths } from 'astro';
import CompareLayout from '../../layouts/Compare.astro';
import CompareHero from '../../components/compare/CompareHero.astro';
import SpecsTableSideBySide from '../../components/compare/SpecsTableSideBySide.astro';
import AutoPhrases from '../../components/compare/AutoPhrases.astro';
import EditorialBlock from '../../components/compare/EditorialBlock.astro';
import FullSpecsTable from '../../components/compare/FullSpecsTable.astro';
import VerdictBlock from '../../components/compare/VerdictBlock.astro';
import RelatedComparisons from '../../components/compare/RelatedComparisons.astro';
import RadarChart from '../../components/compare/RadarChart.tsx';
import StatBars from '../../components/compare/StatBars.tsx';
import CompareSelector from '../../components/compare/CompareSelector.tsx';
import type { CarRow, ComparisonRow } from '../../lib/d1-client.js';
import { parseSpecs } from '../../lib/d1-client.js';
import { generatePhrases } from '../../lib/compare-phrases.js';
import { scoreSpecs, overallScore } from '../../lib/compare-score.js';
import type { RadarData } from '../../lib/compare-score.js';
import { siteConfig } from '../../config/site.js';
import { loadCompareIndex } from '../../lib/compare-index.js';

export interface ComparisonPageProps {
  rowA: CarRow;
  rowB: CarRow;
  comparison: ComparisonRow;
  allPhrases: string[];
  radarA: RadarData;
  radarB: RadarData;
  scoreA: number;
  scoreB: number;
}

export const getStaticPaths: GetStaticPaths = async () => {
  if (process.env.WRANGLER_D1_SKIP) return [];

  const CF_ACCOUNT_ID = import.meta.env.CF_ACCOUNT_ID;
  const CF_API_TOKEN = import.meta.env.CF_API_TOKEN;
  const D1_DATABASE_ID = 'b9d5f455-8e9e-439c-9283-ef1b19addf4b';

  async function d1Query(sql: string, params: any[] = []): Promise<any[]> {
    const res = await fetch(
      `https://api.cloudflare.com/client/v4/accounts/${CF_ACCOUNT_ID}/d1/database/${D1_DATABASE_ID}/query`,
      {
        method: 'POST',
        headers: { Authorization: `Bearer ${CF_API_TOKEN}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ sql, params }),
      }
    );
    const data = await res.json() as any;
    if (!data.success) throw new Error(`D1: ${JSON.stringify(data.errors)}`);
    return data.result?.[0]?.results ?? [];
  }

  try {
    const comparisons: ComparisonRow[] = await d1Query(
      'SELECT id, slug_a, slug_b, url_slug, editorial, kd, monthly_searches, published, created_at, updated_at FROM comparisons WHERE published=1'
    );

    if (comparisons.length === 0) return [];

    const allSlugs = [...new Set(comparisons.flatMap(c => [c.slug_a, c.slug_b]))];
    const placeholders = allSlugs.map(() => '?').join(',');
    const carsArr: CarRow[] = await d1Query(
      `SELECT id, make, model, generation, trim, year, slug, specs_json, hero_url, updated_at FROM cars WHERE slug IN (${placeholders})`,
      allSlugs
    );
    const carMap = new Map(carsArr.map(c => [c.slug, c]));

    const paths = comparisons.map((comp) => {
      const rowA = carMap.get(comp.slug_a);
      const rowB = carMap.get(comp.slug_b);
      if (!rowA || !rowB) return null;

      const specsA = parseSpecs(rowA.specs_json);
      const specsB = parseSpecs(rowB.specs_json);
      const allPhrases = generatePhrases(rowA, rowB);
      const radarA = scoreSpecs(specsA, specsB);
      const radarB = scoreSpecs(specsB, specsA);

      return {
        params: { url_slug: comp.url_slug },
        props: {
          rowA, rowB, comparison: comp,
          allPhrases,
          radarA, radarB,
          scoreA: overallScore(radarA),
          scoreB: overallScore(radarB),
        },
      };
    }).filter(Boolean);

    return paths as any[];
  } catch (e) {
    console.warn('[compare] getStaticPaths: D1 unavailable, skipping comparison pages.', e);
    return [];
  }
};

const { rowA, rowB, comparison, allPhrases, radarA, radarB, scoreA, scoreB } = Astro.props as unknown as ComparisonPageProps;
const compareIndex = await loadCompareIndex();
const specsA = parseSpecs(rowA.specs_json);
const specsB = parseSpecs(rowB.specs_json);

const title = `${rowA.make} ${rowA.model} ${rowA.trim} ${rowA.year} vs ${rowB.make} ${rowB.model} ${rowB.trim} ${rowB.year}`;
const description = allPhrases.slice(0, 2).join(' ');
const canonical = new URL(`/compare/${comparison.url_slug}/`, siteConfig.baseURL).href;

// JSON-LD schema
const schema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: title,
  description,
  url: canonical,
  numberOfItems: 2,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: `${rowA.make} ${rowA.model} ${rowA.trim} ${rowA.year}` },
    { '@type': 'ListItem', position: 2, name: `${rowB.make} ${rowB.model} ${rowB.trim} ${rowB.year}` },
  ],
};
---

<CompareLayout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <div class="compare-selector-wrap">
    <CompareSelector client:visible variant="compact" cars={compareIndex.cars} pairs={compareIndex.pairs} metas={compareIndex.metas} />
  </div>
  <article class="compare-page">
    <CompareHero rowA={rowA} rowB={rowB} scoreA={scoreA} scoreB={scoreB} />
    <SpecsTableSideBySide rowA={rowA} rowB={rowB} specsA={specsA} specsB={specsB} />
    <AutoPhrases phrases={allPhrases} />
    <RadarChart
      client:visible
      labelA={`${rowA.make} ${rowA.model}`}
      labelB={`${rowB.make} ${rowB.model}`}
      dataA={radarA}
      dataB={radarB}
    />
    <StatBars client:visible specsA={specsA} specsB={specsB} labelA={`${rowA.make} ${rowA.model}`} labelB={`${rowB.make} ${rowB.model}`} />
    {comparison.editorial && <EditorialBlock html={comparison.editorial} />}
    <FullSpecsTable specsA={specsA} specsB={specsB} labelA={`${rowA.make} ${rowA.model}`} labelB={`${rowB.make} ${rowB.model}`} />
    <VerdictBlock rowA={rowA} rowB={rowB} radarA={radarA} radarB={radarB} scoreA={scoreA} scoreB={scoreB} />
    <RelatedComparisons currentSlug={comparison.url_slug} slugA={comparison.slug_a} slugB={comparison.slug_b} />
  </article>
</CompareLayout>

<style>
.compare-page { max-width: 1100px; margin: 0 auto; padding: 0 1rem 4rem; }
.compare-page-selector { max-width: 1100px; margin: 1.5rem auto 0; padding: 0 1rem; }
</style>
