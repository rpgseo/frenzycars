---
import Base from '../../layouts/Base.astro';
import { loadMaintenancePages } from '../../lib/maintenance';

const title = 'Maintenance';
const description = 'Practical car troubleshooting, how-to guides, and repair advice from FrenzyCars.';
const pages = loadMaintenancePages();
---
<Base title={title} description={description}>
  <section class="page-hero">
    <div class="container">
      <span class="hero-eyebrow"><span class="dot"></span> {title}</span>
      <h1 class="page-title">{title}</h1>
      <p class="page-lead">{description}</p>
    </div>
  </section>

  <section class="container band">
    <div class="grid grid-3">
      {pages.map((p: any) => (
        <article class="card">
          <a class="card-media" href={`/maintenance/${p.id}/`} aria-label={p.title}>
            <img
              class="card-img"
              src={p.cover || '/images/default-cover.jpg'}
              alt={p.title}
              loading="lazy"
              onerror="this.classList.add('img-failed');this.removeAttribute('src');"
            />
            <span class="card-tag">Maintenance</span>
          </a>
          <div class="card-body">
            <h3 class="card-title"><a href={`/maintenance/${p.id}/`}>{p.title}</a></h3>
            <p class="card-excerpt">{(p.short_answer || '').slice(0, 110)}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</Base>
